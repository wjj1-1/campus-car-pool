/* pages/address/address.wxss */
page {
  background: #f5f5f5;
}

.address-page {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 200rpx;
}

.address-list {
  margin-bottom: 30rpx;
}

.address-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.address-main {
  margin-bottom: 20rpx;
}

.address-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 16rpx;
}

.address-tag.home {
  background: #E3F2FD;
  color: #2196F3;
}

.address-tag.school {
  background: #E8F5E9;
  color: #4CAF50;
}

.address-tag.company {
  background: #FFF3E0;
  color: #FF9800;
}

.address-tag.other {
  background: #F5F5F5;
  color: #666;
}

.address-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.address-info {
  font-size: 26rpx;
  color: #666;
}

.address-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.default-btn {
  font-size: 24rpx;
  color: #4CAF50;
  padding: 8rpx 20rpx;
  border: 1rpx solid #4CAF50;
  border-radius: 20rpx;
}

.default-tag {
  font-size: 22rpx;
  color: #fff;
  background: #4CAF50;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #F44336;
  padding: 8rpx 20rpx;
  background: #FFEBEE;
  border-radius: 20rpx;
}

.empty-state {
  padding: 100rpx 30rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.add-address-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.add-address-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 50rpx;
  border: none;
}

.add-icon {
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.add-address-btn::after {
  border: none;
}

/* 地址编辑弹窗 */
.address-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 40rpx 30rpx 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-form {
  padding: 30rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #F44336;
  margin-right: 6rpx;
}

.form-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.form-input:focus {
  border-color: #4CAF50;
  background: #fff;
}

.picker-value {
  color: #333;
}

.picker-value::after {
  content: '›';
  float: right;
  color: #ccc;
  font-size: 32rpx;
}

.form-textarea {
  width: 100%;
  height: 120rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: #4CAF50;
  background: #fff;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  padding: 24rpx 0;
  font-size: 30rpx;
  border-radius: 50rpx;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
}

.cancel-btn::after,
.confirm-btn::after {
  border: none;
}