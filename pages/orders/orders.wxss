.orders-page {
  min-height: 100vh;
  background: #f4fbf6;
  display: flex;
  flex-direction: column;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #60776a;
  position: relative;
}

.tab-item.active {
  color: #05A854;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #05A854;
  border-radius: 2rpx;
}

.loading {
  padding: 120rpx 0;
  text-align: center;
  color: #60776a;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  color: #60776a;
  font-size: 28rpx;
}

.go-home-btn {
  margin-top: 20rpx;
  background: #05A854;
  color: #fff;
  font-size: 28rpx;
  border-radius: 44rpx;
  width: 300rpx;
}

.order-list {
  flex: 1;
  padding: 20rpx 24rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-time {
  font-size: 30rpx;
  font-weight: 600;
  color: #123527;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-tag.active {
  background: #e8f5e9;
  color: #05A854;
}

.status_tag.ready {
  background: #e3f2fd;
  color: #1976d2;
}

.status-tag.full {
  background: #fff3e0;
  color: #f57c00;
}

.status-tag.completed {
  background: #f3f4f6;
  color: #9ca3af;
}

.status-tag.cancelled {
  background: #fef2f2;
  color: #ef4444;
}

.order-route {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.route-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.route-dot.start {
  background: #05A854;
}

.route-dot.end {
  background: #ef4444;
}

.route-text {
  font-size: 28rpx;
  color: #1F2D28;
}

.route-arrow {
  color: #aab;
  font-size: 24rpx;
}

.order-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  flex-wrap: wrap;
}

.info-item {
  font-size: 24rpx;
  color: #556b5d;
}

.info-divider {
  color: #ccc;
  font-size: 20rpx;
}

.order-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.order-meta text {
  font-size: 22rpx;
  color: #889a8e;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f5f1;
  padding-top: 16rpx;
}

.publisher-info {
  font-size: 24rpx;
  color: #60776a;
}

.order-id {
  font-size: 20rpx;
  color: #aac;
}
