<view class="login-page">
  <view class="brand-area">
    <view class="brand-mark">拼</view>
    <text class="brand-title">校园拼车</text>
    <text class="brand-subtitle">登录后可发布、加入拼车，并提交学生或教师身份认证</text>
  </view>

  <view class="login-panel">
    <view class="field">
      <text class="label">昵称</text>
      <input class="input" data-key="nickname" value="{{nickname}}" bindinput="onInput" placeholder="请输入你的昵称" />
    </view>

    <view class="field">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" data-key="phone" value="{{phone}}" bindinput="onInput" placeholder="用于同行联系" />
    </view>

    <view class="field">
      <text class="label">学校</text>
      <input class="input" data-key="school" value="{{school}}" bindinput="onInput" placeholder="请输入学校名称" />
    </view>

    <view class="two-cols">
      <view class="field half">
        <text class="label">性别</text>
        <picker range="{{genders}}" value="{{genderIndex}}" bindchange="onGenderChange">
          <view class="picker-value">{{genders[genderIndex]}}</view>
        </picker>
      </view>
      <view class="field half">
        <text class="label">身份</text>
        <picker range="{{identities}}" value="{{identityIndex}}" bindchange="onIdentityChange">
          <view class="picker-value">{{identities[identityIndex]}}</view>
        </picker>
      </view>
    </view>

    <view class="agree-row" bindtap="toggleAgree">
      <view class="check {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</view>
      <text>我已了解校园拼车需遵守真实信息、按时赴约和文明同行规则</text>
    </view>

    <button class="primary-btn" bindtap="submitLogin">登录并进入</button>
    <button class="ghost-btn" wx:if="{{nickname && phone}}" bindtap="enterApp">已登录，进入首页</button>
    <button class="ghost-btn" bindtap="goHome">先浏览拼车大厅</button>
  </view>
</view>
