.login-page { min-height: 100vh; padding: 76rpx 32rpx 40rpx; box-sizing: border-box; background: linear-gradient(180deg, #e9f8f0 0%, #f4f8f5 42%, #ffffff 100%); }
.brand-area { padding: 28rpx 4rpx 42rpx; }
.brand-mark { width: 96rpx; height: 96rpx; border-radius: 24rpx; background: #07C160; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 48rpx; font-weight: 800; box-shadow: 0 18rpx 38rpx rgba(7,193,96,.24); }
.brand-title { display: block; margin-top: 30rpx; font-size: 48rpx; font-weight: 800; color: #14251d; }
.brand-subtitle { display: block; margin-top: 14rpx; color: #66706b; font-size: 27rpx; line-height: 1.6; }
.login-panel { padding: 30rpx; border-radius: 20rpx; background: #fff; box-shadow: 0 18rpx 48rpx rgba(18, 46, 31, .08); }
.field { margin-bottom: 24rpx; }
.label { display: block; margin-bottom: 12rpx; font-size: 25rpx; color: #53615c; font-weight: 700; }
.input, .picker-value { height: 88rpx; line-height: 88rpx; padding: 0 24rpx; border-radius: 14rpx; background: #f5f8f6; color: #18241f; font-size: 29rpx; box-sizing: border-box; }
.two-cols { display: flex; gap: 18rpx; }
.half { flex: 1; }
.agree-row { display: flex; gap: 14rpx; align-items: flex-start; margin: 10rpx 0 30rpx; color: #66706b; font-size: 24rpx; line-height: 1.5; }
.check { width: 34rpx; height: 34rpx; border-radius: 50%; border: 2rpx solid #b8c6bf; color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 22rpx; }
.check.checked { border-color: #07C160; background: #07C160; }
.primary-btn { height: 92rpx; line-height: 92rpx; border-radius: 16rpx; background: #07C160; color: #fff; font-size: 31rpx; font-weight: 800; }
.ghost-btn { margin-top: 18rpx; height: 84rpx; line-height: 84rpx; border-radius: 16rpx; background: #eef8f2; color: #05A854; font-size: 28rpx; }
button::after { border: 0; }
