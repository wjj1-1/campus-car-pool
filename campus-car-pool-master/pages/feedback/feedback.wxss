/* pages/feedback/feedback.wxss */
page {
  background: #f5f5f5;
}

.feedback-page {
  min-height: 100vh;
  padding: 30rpx;
}

.feedback-header {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

.feedback-form {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #F44336;
  margin-right: 6rpx;
}

.form-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.form-input:focus {
  border-color: #4CAF50;
  background: #fff;
}

.picker-value {
  color: #333;
}

.picker-value::after {
  content: '›';
  float: right;
  color: #ccc;
  font-size: 32rpx;
}

.feedback-textarea {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
  line-height: 1.6;
}

.feedback-textarea:focus {
  border-color: #4CAF50;
  background: #fff;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.upload-section {
  display: flex;
  flex-direction: column;
}

.upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.upload-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.upload-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.upload-hint {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 16rpx;
}

.feedback-actions {
  margin-bottom: 30rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 26rpx 0;
  border-radius: 50rpx;
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #fff;
}

.submit-btn::after {
  border: none;
}

.feedback-tips {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}