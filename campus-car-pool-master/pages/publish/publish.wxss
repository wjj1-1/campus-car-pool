.publish-page { padding-bottom: 48rpx; }
.publish-hero { padding: 28rpx 6rpx 24rpx; }
.page-title { display: block; font-size: 46rpx; font-weight: 800; color: #05A854; }
.page-subtitle { display: block; margin-top: 12rpx; color: #66706b; font-size: 26rpx; line-height: 1.6; }
.form-card { margin-bottom: 28rpx; }
.field { margin-bottom: 26rpx; }
.field:last-child { margin-bottom: 0; }
.two-cols { display: flex; gap: 18rpx; }
.half { flex: 1; }
.location-field { display: flex; align-items: flex-end; gap: 16rpx; margin-bottom: 26rpx; }
.location-main { flex: 1; }
.point { width: 18rpx; height: 18rpx; border-radius: 50%; margin-bottom: 34rpx; }
.point.start { background: #07C160; box-shadow: 0 0 0 8rpx rgba(31,122,90,.12); }
.point.end { background: #f0a33a; box-shadow: 0 0 0 8rpx rgba(240,163,58,.14); }
.map-pick { width: 104rpx; height: 88rpx; line-height: 88rpx; border-radius: 14rpx; background: #05A854; color: #fff; font-size: 25rpx; }
.submit { height: 92rpx; line-height: 92rpx; }

.hint { display: block; margin-top: 10rpx; color: #7b8580; font-size: 23rpx; line-height: 1.5; }
.mode-banner { margin-bottom: 22rpx; padding: 22rpx 26rpx; border-radius: 18rpx; background: #e9f8f0; color: #05A854; font-size: 30rpx; font-weight: 800; }
.mode-banner.charter { background: #fff4e5; color: #b46b00; }
.mode-desc { display: block; margin-top: 8rpx; font-size: 24rpx; font-weight: 400; }
.passenger-note { margin-bottom: 26rpx; padding: 20rpx 24rpx; border-radius: 14rpx; background: #f4fbf7; color: #05A854; font-size: 25rpx; line-height: 1.6; }

