.header { margin-bottom: 24rpx; }
.title { display: block; font-size: 42rpx; font-weight: 700; }
.subtitle { display: block; margin-top: 10rpx; color: #66706b; font-size: 25rpx; }
.clear { width: 120rpx; height: 64rpx; line-height: 64rpx; background: #edf5f1; color: #07C160; border-radius: 999rpx; font-size: 24rpx; }
.message-card { margin-bottom: 18rpx; position: relative; }
.message-card.unread::before { content: ''; position: absolute; left: 16rpx; top: 32rpx; width: 12rpx; height: 12rpx; border-radius: 50%; background: #e84c3d; }
.msg-title { font-size: 30rpx; font-weight: 700; }
.msg-time { color: #8b948f; font-size: 24rpx; }
.msg-content { display: block; margin-top: 18rpx; color: #53615c; line-height: 1.6; font-size: 26rpx; }
.empty { text-align: center; padding-top: 160rpx; color: #7b8580; }


.msg-link { display: block; margin-top: 14rpx; color: #05A854; font-size: 24rpx; font-weight: 700; }